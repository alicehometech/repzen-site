---
import type { Dict, Locale } from '~/i18n';
import { localePath } from '~/i18n';

interface Props {
  t: Dict;
  lang: Locale;
}
const { t, lang } = Astro.props;

const GH = 'https://github.com/alicehometech/repzen';
const EMAIL = 'mailto:lasmarthome18@gmail.com';
const year = new Date().getFullYear();
const privacyHref = localePath(lang, 'privacy');
const copyright = t.footer.copyright.replace('{year}', String(year));
---

<footer class="border-t border-[var(--line)] py-12">
  <div class="container-page">
    <div class="flex flex-col items-start justify-between gap-8 sm:flex-row sm:items-center">
      <div class="flex items-center gap-2.5">
        <img
          src="/icons/repzen-icon-1024.png"
          alt=""
          width="28"
          height="28"
          class="h-7 w-7 rounded-md"
          loading="lazy"
          decoding="async"
        />
        <span class="text-sm font-semibold tracking-tight">RepZen</span>
      </div>

      <nav class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-[var(--fg-muted)]">
        <a href={privacyHref} class="transition hover:text-[var(--fg)]">{t.footer.privacy}</a>
        <a href={EMAIL} class="transition hover:text-[var(--fg)]">{t.footer.contact}</a>
        <a href={GH} class="transition hover:text-[var(--fg)]" target="_blank" rel="noopener">
          {t.footer.github}
        </a>
      </nav>
    </div>

    <p class="mt-8 text-xs text-[var(--fg-soft)]">{copyright}</p>
  </div>
</footer>
