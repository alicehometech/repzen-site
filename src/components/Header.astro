---
const TESTFLIGHT = 'https://testflight.apple.com/join/T4ygaWD7';
---

<header class="sticky top-0 z-30 border-b border-[var(--line)] bg-[var(--bg)]/85 backdrop-blur-md">
  <div class="container-page flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight" aria-label="RepZen home">
      <img
        src="/icons/repzen-icon-1024.png"
        alt=""
        width="32"
        height="32"
        class="h-8 w-8 rounded-[7px]"
        loading="eager"
        decoding="async"
      />
      <span class="text-[17px]">RepZen</span>
    </a>

    <nav class="hidden items-center gap-7 text-sm font-medium text-[var(--fg-muted)] sm:flex">
      <a href="#exercises" class="transition hover:text-[var(--fg)]">Exercises</a>
      <a href="#how" class="transition hover:text-[var(--fg)]">How it works</a>
      <a href="#privacy" class="transition hover:text-[var(--fg)]">Privacy</a>
      <a href="#faq" class="transition hover:text-[var(--fg)]">FAQ</a>
    </nav>

    <a
      href={TESTFLIGHT}
      class="btn-primary !px-4 !py-2 text-sm"
      target="_blank"
      rel="noopener"
    >
      Join TestFlight
    </a>
  </div>
</header>
