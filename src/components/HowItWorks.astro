---
import type { Dict } from '~/i18n';

interface Props {
  t: Dict;
}
const { t } = Astro.props;

const stepNumbers = ['01', '02', '03'];
---

<section id="how" class="section bg-[var(--card-soft)]">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">{t.how.eyebrow}</p>
      <h2 class="h2 mb-4">{t.how.title}</h2>
      <p class="lede">{t.how.lede}</p>
    </div>

    <ol class="mt-14 grid gap-6 md:grid-cols-3" role="list">
      {
        t.how.steps.map((step, i) => (
          <li class="card relative h-full">
            <span class="text-gradient text-sm font-bold tracking-[0.18em]">{stepNumbers[i]}</span>
            <h3 class="h3 mt-3">{step.title}</h3>
            <p class="mt-3 text-[15px] leading-relaxed text-[var(--fg-muted)]">{step.body}</p>
          </li>
        ))
      }
    </ol>

    <div
      class="mx-auto mt-10 flex max-w-3xl flex-wrap items-center justify-center gap-x-6 gap-y-2 rounded-2xl border border-[var(--line)] bg-[var(--card)] px-6 py-4 text-sm text-[var(--fg-muted)]"
    >
      <span set:html={t.how.chips.slider} />
      <span aria-hidden="true">·</span>
      <span set:html={t.how.chips.diagnostics} />
      <span aria-hidden="true">·</span>
      <span set:html={t.how.chips.transparency} />
    </div>
  </div>
</section>
