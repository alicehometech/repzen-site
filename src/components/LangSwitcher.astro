---
import type { Dict, Locale } from '~/i18n';
import { locales, localeNames, localePath } from '~/i18n';

interface Props {
  t: Dict;
  lang: Locale;
  page?: '' | 'privacy';
}

const { t, lang, page = '' } = Astro.props;
---

<div class="relative" data-lang-switcher>
  <label class="sr-only" for="lang-select">{t.langSwitcher.label}</label>
  <select
    id="lang-select"
    class="appearance-none rounded-full border border-[var(--line-strong)] bg-[var(--card)] px-3 py-1.5 pr-8 text-xs font-semibold text-[var(--fg)] hover:bg-[var(--card-soft)] focus:outline-none focus:ring-2 focus:ring-brand-accent"
    aria-label={t.langSwitcher.label}
    onchange="if(this.value){window.location.href=this.value}"
  >
    {
      locales.map((loc) => (
        <option value={localePath(loc, page)} selected={loc === lang}>
          {localeNames[loc]}
        </option>
      ))
    }
  </select>
  <svg
    aria-hidden="true"
    class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 text-[var(--fg-muted)]"
    width="12"
    height="12"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.4"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <polyline points="6 9 12 15 18 9"></polyline>
  </svg>
</div>
