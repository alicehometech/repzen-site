---
import type { Dict } from '~/i18n';

interface Props {
  t: Dict;
}
const { t } = Astro.props;

const kinds = ['phone', 'watch', 'phone', 'watch'] as const;
---

<section class="section bg-[var(--card-soft)]">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">{t.shots.eyebrow}</p>
      <h2 class="h2 mb-4">{t.shots.title}</h2>
      <p class="lede">{t.shots.lede}</p>
    </div>

    <div class="mx-auto mt-14 grid max-w-5xl grid-cols-2 gap-4 sm:gap-6 md:grid-cols-4">
      {
        t.shots.items.map((s, i) => (
          <div class="flex flex-col items-center gap-3">
            <div
              class:list={[
                'relative w-full overflow-hidden border border-[var(--line-strong)] bg-[var(--card)]',
                kinds[i] === 'phone'
                  ? 'aspect-[9/19] rounded-[28px]'
                  : 'aspect-[1/1.18] rounded-[28px]',
              ]}
            >
              <div class="absolute inset-0 bg-brand-gradient-soft" aria-hidden="true" />
              <div class="absolute inset-0 flex items-center justify-center">
                <span class="rounded-full border border-[var(--line-strong)] bg-[var(--card)]/85 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.16em] text-[var(--fg-muted)] backdrop-blur">
                  {t.shots.coming}
                </span>
              </div>
            </div>
            <div class="text-center">
              <p class="text-sm font-semibold">{s.label}</p>
              <p class="text-xs text-[var(--fg-soft)]">{s.blurb}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
