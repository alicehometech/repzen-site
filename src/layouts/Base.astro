---
import '~/styles/global.css';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  path?: string;
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  path = '/',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonical = siteUrl + path;
const ogImage = siteUrl + '/og-image.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/png" href="/icons/repzen-icon-1024.png" />
    <link rel="apple-touch-icon" href="/icons/repzen-icon-1024.png" />

    <meta name="theme-color" content="#0A84FF" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0A84FF" media="(prefers-color-scheme: dark)" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="RepZen" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="generator" content={Astro.generator} />

    <slot name="head" />
  </head>
  <body class="font-sans">
    <slot />
  </body>
</html>
