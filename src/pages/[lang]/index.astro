---
import Base from '~/layouts/Base.astro';
import Header from '~/components/Header.astro';
import Hero from '~/components/Hero.astro';
import Exercises from '~/components/Exercises.astro';
import HowItWorks from '~/components/HowItWorks.astro';
import Privacy from '~/components/Privacy.astro';
import Screenshots from '~/components/Screenshots.astro';
import BuiltBy from '~/components/BuiltBy.astro';
import FAQ from '~/components/FAQ.astro';
import Footer from '~/components/Footer.astro';
import { dictionaries, locales, defaultLocale } from '~/i18n';
import type { Locale } from '~/i18n';

export async function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLocale)
    .map((lang) => ({
      params: { lang },
      props: { lang },
    }));
}

const { lang } = Astro.props as { lang: Locale };
const t = dictionaries[lang];
---

<Base title={t.meta.title} description={t.meta.description} lang={lang} page="">
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: 'RepZen',
      operatingSystem: 'iOS, watchOS',
      applicationCategory: 'HealthApplication',
      description: t.meta.description,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      url: 'https://repzen.app',
    })}
  />
  <Header t={t} lang={lang} page="" />
  <main id="main">
    <Hero t={t} />
    <Exercises t={t} />
    <HowItWorks t={t} />
    <Privacy t={t} lang={lang} />
    <Screenshots t={t} />
    <BuiltBy t={t} />
    <FAQ t={t} lang={lang} />
  </main>
  <Footer t={t} lang={lang} />
</Base>
