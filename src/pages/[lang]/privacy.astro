---
import Base from '~/layouts/Base.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import PrivacyPolicy from '~/components/PrivacyPolicy.astro';
import { dictionaries, locales, defaultLocale } from '~/i18n';
import type { Locale } from '~/i18n';

export async function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLocale)
    .map((lang) => ({
      params: { lang },
      props: { lang },
    }));
}

const { lang } = Astro.props as { lang: Locale };
const t = dictionaries[lang];
const title = `${t.privacyPage.title} — RepZen`;
const description = t.privacyPage.intro.replace(/<[^>]+>/g, '');
---

<Base title={title} description={description} lang={lang} page="privacy">
  <Header t={t} lang={lang} page="privacy" />
  <main class="container-page py-16 sm:py-20">
    <PrivacyPolicy t={t} />
  </main>
  <Footer t={t} lang={lang} />
</Base>
